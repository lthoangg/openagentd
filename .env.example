# openagentd configuration
#
# Where to put this file:
#   Development  →  .env  (next to this file, in the project root)
#   Production   →  ~/.local/share/openagentd/.env
#
# Only set the values you need. Everything has a sensible default.

# -----------------------------------------------------------------------------
# LLM Provider API Keys
# Set whichever providers you want to use — leave the rest blank.
# -----------------------------------------------------------------------------

GOOGLE_API_KEY=
ZAI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
DEEPSEEK_API_KEY=

# 9Router — local proxy (https://github.com/decolua/9router)
# Generate the key in the 9Router dashboard, then point us at it.
# ROUTER9_BASE_URL defaults to http://localhost:20128/v1.
ROUTER9_API_KEY=
# ROUTER9_BASE_URL=http://localhost:20128/v1

# CLIProxyAPI — local proxy (https://github.com/router-for-me/CLIProxyAPI)
# Set CLIPROXY_API_KEY to whatever your proxy expects ("sk-..." or any value
# if auth is disabled). CLIPROXY_BASE_URL defaults to http://localhost:8317/v1.
CLIPROXY_API_KEY=
# CLIPROXY_BASE_URL=http://localhost:8317/v1

# Vertex AI — requires a GCP project (no separate API key)
# Run: gcloud auth application-default login
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=global

# GitHub Copilot — no API key needed, authenticate via:
#   openagentd auth copilot

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------

# "production" (default) or "development"
# Determines data directory, log level, and config file defaults.
# APP_ENV=production

# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------

# API_HOST=0.0.0.0
# API_PORT=8000
# LOG_LEVEL=INFO
# CORS_ORIGINS=["*"]

# -----------------------------------------------------------------------------
# Data & config paths
# All of these are automatically derived from APP_ENV — only set to override.
# Roots follow the XDG Base Directory spec; see documents/docs/configuration.md.
# -----------------------------------------------------------------------------

# Irreplaceable user data (the SQLite database). Denied to agent fs tools.
#   production default:   ~/.local/share/openagentd/
#   development default:  .openagentd/data/
# OPENAGENTD_DATA_DIR=

# Hand-edited configuration: agents/, skills/, prompt overrides, .env.
#   production default:   ~/.config/openagentd/
#   development default:  .openagentd/config/
# OPENAGENTD_CONFIG_DIR=

# Historical bookkeeping: logs/, telemetry/, otel/, openagentd.pid.
#   production default:   ~/.local/state/openagentd/
#   development default:  .openagentd/state/
# OPENAGENTD_STATE_DIR=

# Regeneratable throwaway: oauth caches, daily quote, etc.
#   production default:   ~/.cache/openagentd/
#   development default:  .openagentd/cache/
# OPENAGENTD_CACHE_DIR=

# Per-session agent workspaces — sibling of DATA_DIR so agent fs tools can write.
#   production default:   ~/.local/share/openagentd-workspace/
#   development default:  .openagentd/workspace/
# OPENAGENTD_WORKSPACE_DIR=

# Shared markdown memory directory — sibling of DATA_DIR.
#   production default:   ~/.local/share/openagentd-memory/
#   development default:  .openagentd/memory/
# AGENT_MEMORY_DIR=

# SQLite database location (defaults to {OPENAGENTD_DATA_DIR}/openagentd.db).
# DATABASE_URL=

# Service tunables (sandbox limits, summarization, title generation, tool-result
# offload, memory cap) are NOT env vars — see documents/docs/configuration.md.
# Override via per-agent .md frontmatter or .openagentd/config/{summarization,title_generation}.md.
